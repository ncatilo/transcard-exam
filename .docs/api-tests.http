@baseUrl = http://localhost:5279
@contentType = application/json

### 1. POST /api/auth/token — Valid credentials (200 OK)

# @name login
POST {{baseUrl}}/api/auth/token HTTP/1.1
Content-Type: {{contentType}}

{
  "clientId": "test-client",
  "clientSecret": "test-secret"
}

###

@token = {{login.response.body.token}}

### 2. POST /api/auth/token — Invalid credentials (401)

POST {{baseUrl}}/api/auth/token HTTP/1.1
Content-Type: {{contentType}}

{
  "clientId": "wrong-client",
  "clientSecret": "wrong-secret"
}

### 3. POST /api/payments — No auth token (401)

POST {{baseUrl}}/api/payments HTTP/1.1
Content-Type: {{contentType}}

{
  "amount": 100.00,
  "currency": "USD",
  "referenceId": "order-no-auth-001"
}

### 4. POST /api/payments — Model validation failure (400)

POST {{baseUrl}}/api/payments HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "amount": 0,
  "currency": "",
  "referenceId": ""
}

### 5. POST /api/payments — Invalid currency code (400)

POST {{baseUrl}}/api/payments HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "amount": 250.00,
  "currency": "XYZ",
  "referenceId": "order-bad-currency-001"
}

### 6. POST /api/payments — New payment (201 Created)

# @name createPayment
POST {{baseUrl}}/api/payments HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "amount": 150.75,
  "currency": "USD",
  "referenceId": "order-ref-001"
}

###

@paymentId = {{createPayment.response.body.id}}

### 7. POST /api/payments — Idempotent retry, same ReferenceId (200 OK)

POST {{baseUrl}}/api/payments HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "amount": 150.75,
  "currency": "USD",
  "referenceId": "order-ref-001"
}

### 8. GET /api/payments/{id} — Payment found (200 OK)

GET {{baseUrl}}/api/payments/{{paymentId}} HTTP/1.1
Authorization: Bearer {{token}}

### 9. GET /api/payments/{id} — Payment not found (404)

GET {{baseUrl}}/api/payments/00000000-0000-0000-0000-000000000000 HTTP/1.1
Authorization: Bearer {{token}}

### 10. GET /api/payments/{id} — No auth token (401)

GET {{baseUrl}}/api/payments/{{paymentId}} HTTP/1.1

### 11. POST /api/payments — Additional currencies

POST {{baseUrl}}/api/payments HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "amount": 5000.00,
  "currency": "EUR",
  "referenceId": "order-eur-001"
}

###

POST {{baseUrl}}/api/payments HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "amount": 750000,
  "currency": "JPY",
  "referenceId": "order-jpy-001"
}

### 12. GET /api/payments/{id}/events — Event history (200 OK)

GET {{baseUrl}}/api/payments/{{paymentId}}/events HTTP/1.1
Authorization: Bearer {{token}}

### 13. GET /api/payments/{id}/events — Payment not found (404)

GET {{baseUrl}}/api/payments/00000000-0000-0000-0000-000000000000/events HTTP/1.1
Authorization: Bearer {{token}}

### 14. POST /api/payments — Expired/tampered token (401)

POST {{baseUrl}}/api/payments HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0IiwiZXhwIjoxNjAwMDAwMDAwfQ.invalid

{
  "amount": 50.00,
  "currency": "GBP",
  "referenceId": "order-expired-001"
}
